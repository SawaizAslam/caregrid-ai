# --- Python ----------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Node / frontend (frontend has its own .gitignore too) -----------
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- IDE / OS --------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Local environment files ----------------------------------------
.env
.env.local
.env.*.local

# --- Project artifacts (regenerable from data/hospitals.csv) --------
data/index/
*.pkl
*.faiss
*.index

# --- Binary docs (HF Spaces rejects raw binaries; use Xet/LFS) ------
*.pdf
# Bun's binary lockfile is rejected by HF Spaces. Stick to package-lock.json.
*.lockb

# Note: data/hospitals.csv is intentionally NOT ignored. The Hugging
# Face Space build needs the dataset present at COPY time. To swap in
# a different dataset, drop it at data/hospitals.csv (or .xlsx) and
# rebuild via `python -m backend.scripts.build_index`.

# --- Model caches ---------------------------------------------------
.cache/
